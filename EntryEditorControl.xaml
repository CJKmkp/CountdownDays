<UserControl x:Class="CountdownDays.EntryEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="400"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0">
            <TextBlock x:Name="TitleLabel" FontWeight="SemiBold"
                       Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBox x:Name="TitleBox" Padding="8,6"/>

            <TextBlock x:Name="NoteLabel" FontWeight="SemiBold"
                       Margin="0,12,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBox x:Name="NoteBox" Padding="8,6"/>

            <TextBlock x:Name="KindLabelText" FontWeight="SemiBold"
                       Margin="0,12,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <ComboBox x:Name="KindCombo" SelectedIndex="0">
                <ComboBoxItem Content="倒计时"/>
                <ComboBoxItem Content="纪念日"/>
            </ComboBox>

            <TextBlock x:Name="TargetLabel" FontWeight="SemiBold"
                       Margin="0,12,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <DatePicker x:Name="DatePicker"/>

            <TextBlock x:Name="NotifyDaysLabelText" FontWeight="SemiBold"
                       Margin="0,12,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            <TextBox x:Name="NotifyDaysBox" Padding="8,6"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>