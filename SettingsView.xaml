<UserControl x:Class="CountdownDays.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
             xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources/>
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <ikw:SimpleStackPanel Spacing="12" Margin="16">

            <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <ikw:SimpleStackPanel Spacing="8">
                    <TextBlock Text="桌面倒计日" FontSize="14" FontWeight="SemiBold"/>
                    <DockPanel>
                        <TextBlock Text="显示 / 隐藏桌面小窗口" VerticalAlignment="Center"/>
                        <Button x:Name="ToggleWindowButton" Content="显示 / 隐藏" Padding="12,4"
                                Click="ToggleWindowButton_Click" HorizontalAlignment="Right"/>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="窗口透明度" VerticalAlignment="Center"/>
                        <Slider x:Name="OpacitySlider" Minimum="40" Maximum="100" SmallChange="5" LargeChange="10"
                                Width="180" HorizontalAlignment="Right" ValueChanged="OpacitySlider_ValueChanged"/>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="界面缩放" VerticalAlignment="Center"/>
                        <Slider x:Name="ScaleSlider" Minimum="0.5" Maximum="2.0" SmallChange="0.1" LargeChange="0.2"
                                Width="180" HorizontalAlignment="Right" ValueChanged="ScaleSlider_ValueChanged"/>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="文字颜色" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Border x:Name="TextColorPreview" Width="28" Height="20" CornerRadius="4"
                                    Background="#FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="TextColorBox" Width="120" Padding="6,4"
                                     LostFocus="TextColorBox_LostFocus" KeyDown="TextColorBox_KeyDown"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="强调颜色" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Border x:Name="AccentColorPreview" Width="28" Height="20" CornerRadius="4"
                                    Background="#C0FF9C" BorderBrush="#33FFFFFF" BorderThickness="1"
                                    Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="AccentColorBox" Width="120" Padding="6,4"
                                     LostFocus="AccentColorBox_LostFocus" KeyDown="AccentColorBox_KeyDown"/>
                        </StackPanel>
                    </DockPanel>
                </ikw:SimpleStackPanel>
            </Border>

            <Border CornerRadius="8" Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <ikw:SimpleStackPanel Spacing="8">
                    <DockPanel>
                        <TextBlock Text="目标列表" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button x:Name="AddButton" Content="添加" Padding="10,4" Margin="0,0,4,0" Click="AddButton_Click"/>
                            <Button x:Name="EditButton" Content="编辑" Padding="10,4" Margin="0,0,4,0" Click="EditButton_Click"/>
                            <Button x:Name="DeleteButton" Content="删除" Padding="10,4" Click="DeleteButton_Click"/>
                        </StackPanel>
                    </DockPanel>
                    <ui:ListView x:Name="EntriesList"
                                 HorizontalContentAlignment="Stretch"
                                 MaxHeight="320"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionChanged="EntriesList_SelectionChanged">
                        <ui:ListView.Template>
                            <ControlTemplate TargetType="ui:ListView">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter HorizontalAlignment="Stretch" />
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </ui:ListView.Template>
                        <ui:ListView.ItemContainerStyle>
                            <Style TargetType="ui:ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="36" />
                            </Style>
                        </ui:ListView.ItemContainerStyle>
                        <ui:ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ui:ListView.ItemsPanel>
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" Margin="4" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:FontIcon Grid.Column="0"
                                                     Width="28" Height="28"
                                                     Margin="0,2,10,0"
                                                     Icon="{x:Static ui:SegoeFluentIcons.Calendar}"
                                                     Opacity="0.85"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{Binding SubText}"
                                                       Margin="0,5,0,0"
                                                       MaxHeight="42"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Opacity="0.76"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>
                </ikw:SimpleStackPanel>
            </Border>

        </ikw:SimpleStackPanel>
    </Grid>
</UserControl>